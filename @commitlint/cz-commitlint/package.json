{
  "name": "@optimizer/cz-commitlint",
  "version": "0.2.0",
  "description": "Commitizen adapter using the commitlint.config.js",
  "main": "./lib/index.js",
  "files": [
    "lib"
  ],
  "scripts": {
    "commit": "git-cz",
    "release": "standard-version -t @optimizer/cz-commitlint@"
  },
  "homepage": "https://github.com/curly210102/commitlint/tree/optimizer/cz-commitlint/@commitlint/cz-commitlint#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/curly210102/commitlint/tree/optimizer/cz-commitlint"
  },
  "engineStrict": true,
  "engines": {
    "node": ">= 10"
  },
  "author": "Curly Brackets <water.curly@outlook.com>",
  "license": "MIT",
  "config": {
    "commitizen": {
      "path": "./@commitlint/cz-commitlint"
    }
  },
  "dependencies": {
    "@commitlint/load": "^12.1.1",
    "@commitlint/types": "^12.1.1",
    "chalk": "^4.1.0",
    "commitizen": "^4.0.3",
    "lodash": "^4.17.21",
    "word-wrap": "^1.2.3"
  },
  "peerDependencies": {
    "inquirer": "^8.0.0"
  },
  "devDependencies": {
    "@types/inquirer": "^7.3.1"
  }
}
